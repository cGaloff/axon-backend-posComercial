# Plantilla de configuración de PRODUCCIÓN.
# En el VPS: copia a .env  ->  cp .env.prod.example .env  ->  y rellena valores reales.
# El archivo .env NUNCA se sube al repo (está en .gitignore).

# --- PostgreSQL ---
POSTGRES_USER=axon_user
POSTGRES_PASSWORD=CAMBIA-esto-por-una-clave-fuerte
POSTGRES_DB=axon_master

# --- JWT ---
# Genera la clave con:  openssl rand -base64 48   (mínimo 32 caracteres)
JWT_KEY=CAMBIA-esto-clave-aleatoria-de-al-menos-32-caracteres
JWT_ISSUER=axon-api
JWT_AUDIENCE=axon-client
JWT_EXPIRES_MINUTES=60
JWT_REFRESH_DAYS=7

# --- Webhooks ---
# Genera con:  openssl rand -base64 24
WEBHOOK_PAYMENT_SECRET=CAMBIA-esto-secreto-webhook

# --- CORS ---
# Dominios EXACTOS de tu frontend, separados por coma (sin barra final).
# Ej: https://app.midominio.com,https://admin.midominio.com
CORS_ALLOWED_ORIGINS=https://app.tudominio.com

# --- Email (SMTP) ---
EMAIL_SMTP_HOST=smtp.tudominio.com
EMAIL_SMTP_PORT=587
EMAIL_FROM_ADDRESS=noreply@tudominio.com
EMAIL_FROM_NAME=AxonPOS
EMAIL_USERNAME=
EMAIL_PASSWORD=
